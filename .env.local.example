# =============================================================================
# Bhavani Store - Environment Variables Example
# Copy this file to .env.local and fill in your values
# =============================================================================

# Site URL (required for metadata and sitemap)
NEXT_PUBLIC_SITE_URL=https://bhavanistore.in

# Google Analytics (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# WhatsApp Business number (without + prefix)
NEXT_PUBLIC_WHATSAPP_NUMBER=919360333025

# Google Search Console verification code
# NEXT_PUBLIC_GOOGLE_VERIFICATION=your-verification-code

# Contact Email
NEXT_PUBLIC_CONTACT_EMAIL=harishbalajipmk@gmail.com
